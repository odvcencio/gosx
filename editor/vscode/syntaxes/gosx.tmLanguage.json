{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GoSX",
  "scopeName": "source.gosx",
  "patterns": [
    { "include": "#directives" },
    { "include": "#jsx-tags" },
    { "include": "#expr-containers" },
    { "include": "source.go" }
  ],
  "repository": {
    "directives": {
      "patterns": [
        {
          "match": "//gosx:(island|engine|capabilities)\\b.*$",
          "name": "meta.annotation.gosx"
        }
      ]
    },
    "expr-containers": {
      "patterns": [
        {
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.gosx" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.gosx" }
          },
          "name": "meta.embedded.expression.gosx",
          "patterns": [
            { "include": "source.go" }
          ]
        }
      ]
    },
    "jsx-tags": {
      "patterns": [
        {
          "begin": "(</?)([A-Za-z_][A-Za-z0-9_.-]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.gosx" },
            "2": { "name": "entity.name.tag.gosx" }
          },
          "end": "(/?>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.end.gosx" }
          },
          "name": "meta.tag.gosx",
          "patterns": [
            {
              "match": "([A-Za-z_:][A-Za-z0-9_:.-]*)(=)",
              "captures": {
                "1": { "name": "entity.other.attribute-name.gosx" },
                "2": { "name": "keyword.operator.assignment.gosx" }
              }
            },
            {
              "match": "\"[^\"]*\"",
              "name": "string.quoted.double.gosx"
            },
            {
              "match": "\\{\\.\\.\\.",
              "name": "keyword.operator.spread.gosx"
            },
            { "include": "#expr-containers" }
          ]
        }
      ]
    }
  }
}
